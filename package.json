{
  "name": "racing-game",
  "version": "2.0.0",
  "description": "Production-ready 3D desert racing game built with React, React Three Fiber, and Rapier",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@react-three/drei": "^9.92.0",
    "@react-three/fiber": "^8.15.0",
    "@react-three/rapier": "^1.2.0",
    "lodash-es": "^4.17.21",
    "react": "^18.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.2.0",
    "three": "^0.160.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.30.1",
    "vite": "^5.0.0",
    "vitest": "^3.1.2"
  },
  "scripts": {
    "dev": "vite --host",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest",
    "test:run": "vitest run",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run test:run && npm run build"
  }
}
